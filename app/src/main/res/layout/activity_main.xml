<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC">

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VocabLab"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="24dp"/>

    <LinearLayout
        android:id="@+id/layoutLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_pill"
        android:backgroundTint="#E0E6ED"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="@+id/textTitle"
        app:layout_constraintBottom_toBottomOf="@+id/textTitle"
        app:layout_constraintStart_toEndOf="@+id/textTitle"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/btnLangEN"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#3498DB"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/btnLangDE"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DE"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:textColor="#7F8C8D"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/menuIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_menu"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@+id/textTitle"
        app:layout_constraintBottom_toBottomOf="@+id/textTitle"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="24dp"/>

    <ImageView
        android:id="@+id/btnInventory"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@+id/menuIcon"
        app:layout_constraintEnd_toStartOf="@+id/menuIcon"
        android:layout_marginEnd="16dp"/>

    <ImageView
        android:id="@+id/btnAddWordPage"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_input_add"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@+id/btnInventory"
        app:layout_constraintEnd_toStartOf="@+id/btnInventory"
        android:layout_marginEnd="16dp"/>

    <LinearLayout
        android:id="@+id/layoutCounters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@+id/textTitle">

        <TextView
            android:id="@+id/textRepeatCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tekrar: 0"
            android:textColor="#E74C3C"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#FDEDEC"
            android:padding="8dp"
            android:gravity="center"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textTotalCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Top: 0"
            android:textColor="#3498DB"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#EBF5FB"
            android:padding="8dp"
            android:gravity="center"
            android:layout_marginHorizontal="8dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textKnownCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bildiğim: 0"
            android:textColor="#27AE60"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#E9F7EF"
            android:padding="8dp"
            android:gravity="center"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/flashCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginVertical="32dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutCounters"
        app:layout_constraintBottom_toTopOf="@+id/layoutActionButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/textWord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yükleniyor..."
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/iconSpeech"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_speech"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <TextView
                android:id="@+id/textSentence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="18sp"
                android:textStyle="italic"
                android:textColor="#7F8C8D"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/textMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#E67E22"
                android:visibility="invisible"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnShowMeaning"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Anlamını Göster"
                android:textSize="16sp"
                android:backgroundTint="#34495E"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSwipeLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_delete"
            app:backgroundTint="#FFFFFF"
            app:tint="#E74C3C"
            app:fabSize="normal"
            android:layout_marginEnd="48dp"
            app:elevation="8dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSwipeRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#FFFFFF"
            app:tint="#27AE60"
            app:fabSize="normal"
            app:elevation="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnTranslate"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_speech"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="VocabLab"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Progress Pills -->
    <LinearLayout
        android:id="@+id/layoutPills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <TextView
            android:id="@+id/textTotalCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Toplam: 0"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textKnownCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:backgroundTint="@color/secondary_container"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Bilinen: 0"
            android:textColor="@color/on_secondary_container"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textRepeatCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:backgroundTint="@color/tertiary_container"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Tekrar: 0"
            android:textColor="@color/on_tertiary_container"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Language Indicator -->
    <LinearLayout
        android:id="@+id/layoutLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_pill"
        android:backgroundTint="@color/surface_container_highest"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutPills">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLangEN"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:text="EN"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="999dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLangDE"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:text="DE"
            android:textAllCaps="false"
            android:textColor="@color/on_surface_variant"
            app:backgroundTint="@color/surface_container_high"
            app:cornerRadius="999dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="8dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/outline" />

        <TextView
            android:id="@+id/textLangTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TR"
            android:textColor="@color/primary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Card Stack Area -->
    <FrameLayout
        android:id="@+id/cardStack"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:maxHeight="420dp"
        app:layout_constraintBottom_toTopOf="@id/layoutActions"
        app:layout_constraintTop_toBottomOf="@id/layoutLanguage">

        <!-- Visual Stack Layers -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="40dp"
            android:alpha="0.3"
            android:background="@drawable/bg_card" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="20dp"
            android:alpha="0.6"
            android:background="@drawable/bg_card" />

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/textWord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Serendipity"
                    android:textColor="@color/on_surface"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/translationArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="invisible"
                    tools:visibility="visible">

                    <View
                        android:layout_width="64dp"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant" />

                    <TextView
                        android:id="@+id/textMeaning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Mutlu Tesadüf"
                        android:textColor="@color/primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textSentence"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Finding this rare book was pure serendipity."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="16sp"
                        android:textStyle="italic" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnShowMeaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/surface_variant"
                    android:text="Çeviriyi Gör"
                    android:textColor="@color/on_surface"
                    app:cornerRadius="999dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwipeLeft"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/surface_container_high"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Tekrarla"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_popup_sync"
            app:iconGravity="top"
            app:iconPadding="4dp"
            app:iconTint="@color/tertiary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwipeRight"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/primary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Öğrendim"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/checkbox_on_background"
            app:iconGravity="top"
            app:iconPadding="4dp"
            app:iconTint="@color/white" />
    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        app:elevation="8dp"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="88dp"
        android:contentDescription="@string/app_name"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
